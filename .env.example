# SST Voice Pipecat - Environment Variables
# Copy this file to .env and fill in your values

# Server Config
WEBSOCKET_SERVER=fast_api
PORT=7860
PUBLIC_WS_URL=wss://rtstt-demo.securityzone.vn/ws

# OpenAI API (required for OpenAI mode)
OPENAI_API_KEY=sk-proj-xxx

# Google API (for Gemini)
GOOGLE_API_KEY=AIza...

# ElevenLabs TTS
ELEVENLABS_API_KEY=sk_xxx

# Bot Implementation: 'openai' or 'gemini'
BOT_IMPLEMENTATION=openai

# Custom TTS Service
TTS_BASE_URL=http://localhost:8720
TTS_VOICE_ID=Giọng nữ 1

# STT - WhisperX API (fallback for non-Vietnamese)
STT_BASE_URL=http://localhost:5772

# STT - Qwen Chat API (primary, Qwen3-ASR)
QWEN_STT_URL=http://localhost:8801

# VAD (Voice Activity Detection)
VAD_CONFIDENCE=0.5
VAD_START_SECS=0.2
VAD_STOP_SECS=0.8
VAD_MIN_VOLUME=0.85

# N8N Webhook LLM
LLM_BASE_URL=https://your-n8n-server.com/webhook/your-webhook

# RAGFlow Config
RAG_LLM_BASE_URL=https://your-ragflow-server.com/api/v1/chats_openai/xxx/chat/completions
RAG_API_KEY=ragflow-xxx

# Notify URL
NOTIFY_URL=https://your-domain.com/api/v1/ws/notify

# Welcome Message
WELCOME_MSG=Xin chào, tôi có thể giúp gì cho bạn?

# Concurrent Users
MAX_CONCURRENT_USERS=10
BUSY_MESSAGE=Xin lỗi, hệ thống đang bận. Vui lòng thử lại sau.
